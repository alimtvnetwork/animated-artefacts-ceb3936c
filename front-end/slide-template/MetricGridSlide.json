{
  "templateName": "MetricGridSlide",
  "depends": {
    "color": "../themes/noir-gold/colors.json",
    "theme": "../themes/noir-gold/themes.json"
  },
  "fields": {
    "eyebrow":  { "type": "string",   "required": false },
    "title":    { "type": "string",   "required": false },
    "subtitle": { "type": "string",   "required": false },
    "metrics":  { "type": "Metric[]", "required": true, "description": "2–6 cells. Each is { value, label, caption?, accent? }. Layout auto-derives: 2→1×2, 3→1×3, 4→2×2, 5/6→2×3." }
  },
  "defaults": {
    "transition": "PushIn",
    "textAnimation": "Stagger"
  }
}
